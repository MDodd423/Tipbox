<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/activity_sub"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/layout_padding"
    tools:context=".SubActivity">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/relativeLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/settingsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/tipLayout1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <EditText
                        android:id="@+id/tip1Text"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".7"
                        android:inputType="numberDecimal"
                        android:maxLength="5"
                        tools:ignore="Autofill" />

                    <Button
                        android:id="@+id/tip1Button"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".3"
                        android:labelFor="@id/tip1Text"
                        android:onClick="buttontip1" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tipLayout2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <EditText
                        android:id="@+id/tip2Text"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".7"
                        android:inputType="numberDecimal"
                        android:maxLength="5"
                        tools:ignore="Autofill" />

                    <Button
                        android:id="@+id/tip2Button"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".3"
                        android:labelFor="@id/tip2Text"
                        android:onClick="buttontip2" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tipLayout3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <EditText
                        android:id="@+id/tip3Text"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".7"
                        android:inputType="numberDecimal"
                        android:maxLength="5"
                        tools:ignore="Autofill" />

                    <Button
                        android:id="@+id/tip3Button"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".3"
                        android:labelFor="@id/tip3Text"
                        android:onClick="buttontip3" />

                </LinearLayout>

                <LinearLayout
                    android:id="@+id/tipLayout4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <EditText
                        android:id="@+id/tip4Text"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".7"
                        android:inputType="numberDecimal"
                        android:maxLength="5"
                        tools:ignore="Autofill" />

                    <Button
                        android:id="@+id/tip4Button"
                        android:layout_width="@dimen/zero_dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".3"
                        android:labelFor="@id/tip4Text"
                        android:onClick="buttontip4" />

                </LinearLayout>
            </LinearLayout>

            <Button
                android:id="@+id/subResetButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/settingsLayout"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="@dimen/margin100"
                android:onClick="resetTipAmounts"
                android:text="@string/resetButton_text" />

        </RelativeLayout>
    </ScrollView>
</RelativeLayout>